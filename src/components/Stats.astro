<section style="position: relative; border-bottom: 1px solid var(--c-border); background: var(--c-bg);">
  <div class="technical-grid gsap-stagger-container">
    <div class="technical-item third-item gsap-stagger-item" style="opacity: 0;">
      <div class="mono" style="color: var(--c-t3); margin-bottom: 12px;">/ 01 FIELD RECORD</div>
      <div style="font-family: var(--f-disp); font-size: clamp(48px, 6vw, 64px); font-weight: 700; line-height: 1; color: var(--c-paper); letter-spacing: -0.02em;">1000+</div>
      <div style="margin-top: 8px; color: var(--c-t2); font-size: 16px;">Projects Completed.</div>
    </div>
    
    <div class="technical-item third-item gsap-stagger-item" style="opacity: 0;">
      <div class="mono" style="color: var(--c-t3); margin-bottom: 12px;">/ 02 EXPERIENCE</div>
      <div style="font-family: var(--f-disp); font-size: clamp(48px, 6vw, 64px); font-weight: 700; line-height: 1; color: var(--c-paper); letter-spacing: -0.02em;">11+</div>
      <div style="margin-top: 8px; color: var(--c-t2); font-size: 16px;">Years Active.</div>
    </div>
    
    <div class="technical-item third-item gsap-stagger-item" style="opacity: 0;">
      <div class="mono" style="color: var(--c-t3); margin-bottom: 12px;">/ 03 CAPACITY</div>
      <div style="font-family: var(--f-disp); font-size: clamp(48px, 6vw, 64px); font-weight: 700; line-height: 1; color: var(--c-paper); letter-spacing: -0.02em;">150+</div>
      <div style="margin-top: 8px; color: var(--c-t2); font-size: 16px;">Projects per Year.</div>
    </div>
  </div>
</section>
