---
import HeroBackground from './HeroBackground.tsx';
---

<section style="position: relative; width: 100%; height: 100svh; min-height: 600px; overflow: hidden; background: var(--c-bg); border-bottom: 1px solid var(--c-border);">
  <div class="grid-overlay"></div>
  <HeroBackground client:load />

  <!-- gradient veil so text is readable -->
  <div style="position: absolute; inset: 0; z-index: 2; pointer-events: none; background: linear-gradient(90deg, var(--c-bg) 0%, rgba(15,17,21,.85) 35%, transparent 100%);"></div>

  <div class="wrap hero-wrap" style="position: relative; z-index: 4; height: 100%; display: flex; flex-direction: column; justify-content: center;">
    <div class="hero-utility" style="position: absolute; top: 0; left: 0; width: 100%; display: flex; justify-content: space-between; padding: 100px 4vw 0 4vw; flex-shrink: 0; flex-wrap: wrap; gap: 16px; box-sizing: border-box;">
      <div>
        <div class="mono" style="color:rgba(169,188,212,.7)">Land surveyors</div>
        <div class="mono" style="color:#A9BCD4;margin-top:5px">Across India · Since 2014</div>
      </div>
      <div class="mono hero-location" style="text-align:right">
        <div style="color:var(--c-gold)">13.0023° N · 80.0945° E</div>
        <div style="color:#A9BCD4;margin-top:5px">Field operations · All days</div>
      </div>
    </div>

    <div style="max-width: 100%; width: 100%; margin-top: 60px;">
      <h1 style="font-family: var(--f-disp); font-weight: 700; font-size: clamp(56px, 11vw, 110px); line-height: 1.05; letter-spacing: -0.02em; max-width: 900px;">
        <span style="display: block;">Field Operations.</span>
        <span style="display: block;" class="text-scan">Data Acquisition.</span>
      </h1>
      
      <p style="font-size: clamp(16px, 1.5vw, 18px); color: var(--c-t2); max-width: 44ch; margin-top: 32px; line-height: 1.6;">
        Topographic surveying, boundary fixing, and construction marking. Direct field execution since 2014.
      </p>

      <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 32px;">
        <a class="btn-wa" href="https://wa.me/918072807474">
          <svg viewBox="0 0 24 24" fill="currentColor" style="width: 20px; height: 20px;"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Zm5.5 14.1c-.2.7-1.3 1.3-1.9 1.4-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.7-.6-2.9-1.3-4.8-4.2-5-4.4-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.3-.3.6-.4.8-.4h.6c.2 0 .4 0 .6.5s.8 1.9.9 2c.1.1.1.3 0 .5-.1.2-.2.3-.3.5l-.5.6c-.1.1-.3.3-.1.6.2.3.8 1.3 1.7 2.1 1.2 1.1 2.2 1.4 2.5 1.5.3.1.5.1.7-.1.2-.2.8-.9 1-1.2.2-.3.4-.3.7-.2.3.1 1.8.9 2.1 1 .3.2.5.2.6.4.1.1.1.7-.1 1.3Z"/></svg>
          WhatsApp us now
        </a>
        <a class="btn-ghost" href="tel:+918072807474">Call 80728 07474</a>
      </div>

      <div style="display: flex; gap: 20px; flex-wrap: wrap; margin-top: 32px;">
        <span style="display: flex; align-items: center; gap: 7px; font-family: var(--f-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: #7E97B5;">
          <svg viewBox="0 0 14 14" style="width: 10px; height: 10px; color: var(--c-gold);"><circle cx="7" cy="7" r="4.4" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M7 0v2.6M7 11.4v2.6M0 7h2.6M11.4 7h2.6" stroke="currentColor" stroke-width="1.4" fill="none"/></svg>
          10000+ projects
        </span>
        <span style="display: flex; align-items: center; gap: 7px; font-family: var(--f-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: #7E97B5;">
          <svg viewBox="0 0 14 14" style="width: 10px; height: 10px; color: var(--c-gold);"><circle cx="7" cy="7" r="4.4" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M7 0v2.6M7 11.4v2.6M0 7h2.6M11.4 7h2.6" stroke="currentColor" stroke-width="1.4" fill="none"/></svg>
          12+ years
        </span>
        <span style="display: flex; align-items: center; gap: 7px; font-family: var(--f-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: #7E97B5;">
          <svg viewBox="0 0 14 14" style="width: 10px; height: 10px; color: var(--c-gold);"><circle cx="7" cy="7" r="4.4" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M7 0v2.6M7 11.4v2.6M0 7h2.6M11.4 7h2.6" stroke="currentColor" stroke-width="1.4" fill="none"/></svg>
          5 Teams Active
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  @media(max-width: 600px) {
    .hero-location {
      text-align: left !important;
    }
  }
</style>
