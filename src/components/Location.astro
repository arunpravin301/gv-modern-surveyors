---
// Location.astro
---

<section id="location" style="background: var(--c-bg); border-top: 1px solid var(--c-border); padding: 130px 0; overflow: hidden; position: relative;">
  <div class="loc-grid gsap-stagger-container" style="max-width: 1400px; margin: 0 auto; padding: 0 4vw; display: grid; grid-template-columns: 1fr 1fr; gap: 6vw; alignItems: center;">
    
    <div class="gsap-stagger-item" style="opacity: 0;">
      <div className="mono" style="color: var(--c-gold); margin-bottom: 24px; display: flex; align-items: center; gap: 12px;">
        / 05 REACH US
        <span style="display: block; width: 80px; height: 1px; background: var(--c-border);"></span>
      </div>
      <h2 style="font-family: var(--f-disp); font-size: clamp(34px, 4.6vw, 60px); color: var(--c-paper); font-weight: 700; max-width: 13ch;">
        Based in Chennai. Working across India.
      </h2>
      
      <div style="margin-top: 40px; display: grid; gap: 24px;">
        <div style="display: flex; gap: 16px; align-items: flex-start; font-size: 15px; color: var(--c-t2); max-width: 46ch;">
          <div style="width: 16px; height: 16px; flex-shrink: 0; margin-top: 4px;">
            <svg viewBox="0 0 14 14">
              <circle cx="7" cy="7" r="4.4" fill="none" stroke="var(--c-gold)" stroke-width="1.4"/>
              <path d="M7 0v2.6M7 11.4v2.6M0 7h2.6M11.4 7h2.6" stroke="var(--c-gold)" stroke-width="1.4"/>
            </svg>
          </div>
          No.117, Sammandhan Nagar Main Road, Kundrathur, Chennai 600069.
        </div>
        <div style="display: flex; gap: 16px; align-items: flex-start; font-size: 15px; color: var(--c-t2); max-width: 46ch;">
          <div style="width: 16px; height: 16px; flex-shrink: 0; margin-top: 4px;">
            <svg viewBox="0 0 14 14">
              <circle cx="7" cy="7" r="4.4" fill="none" stroke="var(--c-gold)" stroke-width="1.4"/>
              <path d="M7 0v2.6M7 11.4v2.6M0 7h2.6M11.4 7h2.6" stroke="var(--c-gold)" stroke-width="1.4"/>
            </svg>
          </div>
          Field teams cover all of South Chennai daily, with project work nationwide.
        </div>
        <div style="display: flex; gap: 16px; align-items: flex-start; font-size: 15px; color: var(--c-t2); max-width: 46ch;">
          <div style="width: 16px; height: 16px; flex-shrink: 0; margin-top: 4px;">
            <svg viewBox="0 0 14 14">
              <circle cx="7" cy="7" r="4.4" fill="none" stroke="var(--c-gold)" stroke-width="1.4"/>
              <path d="M7 0v2.6M7 11.4v2.6M0 7h2.6M11.4 7h2.6" stroke="var(--c-gold)" stroke-width="1.4"/>
            </svg>
          </div>
          Reach us on WhatsApp or call. We reply the same day, every day.
        </div>
      </div>

      <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 40px;">
        <a href="#" class="loc-area">Surveyor in Kundrathur</a>
        <a href="#" class="loc-area">Land survey Porur</a>
        <a href="#" class="loc-area">Land survey Tambaram</a>
      </div>
    </div>

    <div class="gsap-stagger-item" style="position: relative; border: 1px solid var(--c-border); background: var(--c-bg-alt); padding: 8px; opacity: 0;">
      <span style="position: absolute; left: 24px; top: 24px; background: var(--c-bg); color: var(--c-gold); font-family: var(--f-mono); font-size: 10.5px; letter-spacing: 0.06em; padding: 6px 10px; border: 1px solid var(--c-border); z-index: 2;">
        13.0023° N · 80.0945° E
      </span>
      <iframe 
        title="GV Modern Surveyors location" 
        loading="lazy" 
        src="https://www.google.com/maps?q=Kundrathur%2C%20Chennai%20600069&output=embed"
        style="width: 100%; height: 500px; border: 0; display: block; filter: grayscale(1) contrast(1.2) brightness(0.6);"
      ></iframe>
    </div>

  </div>
</section>

<style>
  .loc-area {
    font-size: 13.5px;
    font-weight: 700;
    color: var(--c-paper);
    text-decoration: none;
    border: 1px solid var(--c-border);
    background: var(--c-bg-alt);
    padding: 10px 17px;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .loc-area:hover {
    background: var(--c-gold);
    border-color: var(--c-gold);
    color: var(--c-bg);
  }

  @media(max-width: 1024px) {
    .loc-grid {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
    }
  }
</style>
