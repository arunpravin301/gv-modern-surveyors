---
// Footer.astro
---

<footer style="background: #04080D; border-top: 1px solid var(--c-border); padding: 80px 0 40px;">
  <div style="max-width: 1400px; margin: 0 auto; padding: 0 4vw;">
    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 6vw;">
      
      <div>
        <div style="font-family: var(--f-disp); font-weight: 800; font-size: 28px; color: var(--c-paper); margin-bottom: 24px; letter-spacing: 0.02em;">
          GV MODERN <em style="font-style: normal; color: var(--c-gold);">SURVEYORS</em>
        </div>
        <p style="color: var(--c-t2); font-size: 15px; max-width: 44ch; line-height: 1.6;">
          Professional land survey and engineering layout services. Serving developers, architects, and private landowners across South India since 2012.
        </p>
      </div>
      
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <h6 class="mono" style="color: var(--c-gold); font-size: 12px; margin-bottom: 12px;">COMPANY</h6>
        <a href="/services" class="foot-link">Services</a>
        <a href="/projects" class="foot-link">Projects</a>
        <a href="/about" class="foot-link">About</a>
        <!-- <a href="/guides" class="foot-link">Guides</a> -->
      </div>
      
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <h6 class="mono" style="color: var(--c-gold); font-size: 12px; margin-bottom: 12px;">LEGAL</h6>
        <a href="#" class="foot-link">Privacy Policy</a>
        <a href="#" class="foot-link">Terms of Service</a>
        <a href="#" class="foot-link">Refund Policy</a>
      </div>
      
    </div>
    
    <div style="border-top: 1px solid var(--c-border); margin-top: 80px; padding-top: 32px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 16px; font-family: var(--f-mono); font-size: 11px; color: var(--c-t3); letter-spacing: 0.05em;">
      <span>© 2026 GV MODERN SURVEYORS. ALL RIGHTS RESERVED.</span>
      <span>13.0023° N · 80.0945° E</span>
    </div>
  </div>
</footer>

<style>
  .foot-link {
    color: var(--c-t2);
    text-decoration: none;
    font-size: 15px;
    transition: color 0.2s;
  }
  .foot-link:hover {
    color: var(--c-paper);
  }

  @media(max-width: 768px) {
    div[style*="grid-template-columns: 2fr"] {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
    }
  }
</style>
