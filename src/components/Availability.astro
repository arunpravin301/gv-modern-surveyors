---
// Availability.astro
---

<section style="background: var(--c-bg); border-top: 1px solid var(--c-border); position: relative; overflow: hidden; padding: 120px 0;">
  <div class="technical-grid gsap-stagger-container" style="border: none; max-width: 1400px; margin: 0 auto;">
    <div class="technical-item half-item gsap-stagger-item" style="border: none; opacity: 0;">
      <div class="mono" style="color: var(--c-gold); margin-bottom: 20px;">/ 02 AVAILABILITY</div>
      <h2 style="font-family: var(--f-disp); font-size: clamp(36px, 4.8vw, 72px); line-height: 0.96; color: var(--c-paper); font-weight: 700; max-width: 14ch;">
        We show up. <br/><span style="color: var(--c-gold);">Every single day.</span>
      </h2>
    </div>
    
    <div class="technical-item half-item gsap-stagger-item" style="border: none; display: flex; flex-direction: column; gap: 40px; justify-content: center; opacity: 0;">
      <div style="border-left: 2px solid var(--c-gold); padding-left: 24px;">
        <strong style="display: block; font-size: 17px; font-weight: 700; color: var(--c-paper); margin-bottom: 8px;">Same-day reply, guaranteed.</strong>
        <p style="font-size: 15px; color: var(--c-t2); line-height: 1.6; max-width: 36ch;">Send us a message now. You will hear back today, with a visit date and the team assigned to your site.</p>
      </div>
      
      <div style="border-left: 2px solid var(--c-gold); padding-left: 24px;">
        <strong style="display: block; font-size: 17px; font-weight: 700; color: var(--c-paper); margin-bottom: 8px;">No weekends off. No waiting list.</strong>
        <p style="font-size: 15px; color: var(--c-t2); line-height: 1.6; max-width: 36ch;">We run field teams every day of the week. If you need a survey done this week, we can almost always make it happen.</p>
      </div>
      
      <a class="btn" href="https://wa.me/918072807474" style="align-self: flex-start; background: var(--c-gold); color: var(--c-bg); padding: 16px 32px; font-weight: 700; text-decoration: none; margin-top: 12px; display: inline-flex; align-items: center; gap: 8px;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
        Check availability on WhatsApp
      </a>
    </div>
  </div>

  <div class="band-tick" aria-hidden="true" style="position: absolute; left: 0; right: 0; bottom: 32px; height: 28px; z-index: 1;">
    <svg viewBox="0 0 1200 28" preserveAspectRatio="none" style="width: 100%; height: 100%;">
      <line x1="0" y1="14" x2="1200" y2="14" stroke="var(--c-border)" stroke-width="1"/>
      <g id="ticks" fill="var(--c-border)">
        <!-- Generated by JS usually, we'll do static CSS animation -->
      </g>
      <line class="runner" x1="0" y1="5" x2="0" y2="23" stroke="var(--c-gold)" stroke-width="2" style="filter: drop-shadow(0 0 5px rgba(224,165,38,0.8));" />
    </svg>
  </div>
</section>

<style>
  .runner {
    animation: runLine 3s linear infinite;
  }
  @keyframes runLine {
    0% { transform: translateX(0); }
    100% { transform: translateX(1200px); }
  }
</style>
