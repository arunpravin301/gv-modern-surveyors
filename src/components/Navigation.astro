---
const pathname = Astro.url.pathname;
const currentPath = pathname.replace(/\/$/, ""); // remove trailing slash
---
<header class="brutal-nav" style="position: fixed; top: 0; left: 0; width: 100%; z-index: 100; background: rgba(11,20,26,0.9); backdrop-filter: blur(8px); border-bottom: 1px solid var(--c-border);">
  <div class="wrap" style="height: 80px; display: flex; align-items: center; justify-content: space-between;">
    <a href="/" style="display: flex; align-items: center; z-index: 102;">
      <img src="/logo.png" alt="GV Modern Surveyors" style="height: clamp(32px, 5vw, 48px); object-fit: contain;" />
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav" style="display: flex; align-items: center; gap: clamp(16px, 2.5vw, 32px); font-size: clamp(13px, 1.5vw, 14px); font-weight: 500;">
      <a href="/" class={`nav-link ${currentPath === '' ? 'active' : ''}`}>Home</a>
      <a href="/services" class={`nav-link ${currentPath === '/services' ? 'active' : ''}`}>Services</a>
      <a href="/projects" class={`nav-link ${currentPath === '/projects' ? 'active' : ''}`}>Projects</a>
      <a href="/about" class={`nav-link ${currentPath === '/about' ? 'active' : ''}`}>About</a>
      <!-- <a href="/guides" class={`nav-link ${currentPath === '/guides' ? 'active' : ''}`}>Guides</a> -->
      <a href="/contact" class={`nav-link ${currentPath === '/contact' ? 'active' : ''}`}>Contact</a>
      <a class="btn-wa" href="https://wa.me/918072807474" style="padding: 10px 20px; font-size: clamp(13px, 1.5vw, 14px); border-radius: 0; border: 1px solid var(--c-wa); display: flex; align-items: center; gap: 8px;">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width: 16px; height: 16px;"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Zm5.5 14.1c-.2.7-1.3 1.3-1.9 1.4-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.7-.6-2.9-1.3-4.8-4.2-5-4.4-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.3-.3.6-.4.8-.4h.6c.2 0 .4 0 .6.5s.8 1.9.9 2c.1.1.1.3 0 .5-.1.2-.2.3-.3.5l-.5.6c-.1.1-.3.3-.1.6.2.3.8 1.3 1.7 2.1 1.2 1.1 2.2 1.4 2.5 1.5.3.1.5.1.7-.1.2-.2.8-.9 1-1.2.2-.3.4-.3.7-.2.3.1 1.8.9 2.1 1 .3.2.5.2.6.4.1.1.1.7-.1 1.3Z"/></svg>
        WhatsApp Us
      </a>
    </nav>

    <!-- Mobile Hamburger Toggle -->
    <button id="menu-toggle" class="mobile-toggle" aria-label="Toggle Menu" style="background:none; border:none; color:var(--c-paper); cursor:pointer; z-index: 102;">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12" class="l1" style="transition: transform 0.3s, opacity 0.3s;" />
        <line x1="3" y1="6" x2="21" y2="6" class="l2" style="transition: transform 0.3s;" />
        <line x1="3" y1="18" x2="21" y2="18" class="l3" style="transition: transform 0.3s;" />
      </svg>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-menu" class="mobile-drawer">
    <nav class="mobile-nav">
      <a href="/" class={`nav-link ${currentPath === '' ? 'active' : ''}`}>Home</a>
      <a href="/services" class={`nav-link ${currentPath === '/services' ? 'active' : ''}`}>Services</a>
      <a href="/projects" class={`nav-link ${currentPath === '/projects' ? 'active' : ''}`}>Projects</a>
      <a href="/about" class={`nav-link ${currentPath === '/about' ? 'active' : ''}`}>About</a>
      <!-- <a href="/guides" class={`nav-link ${currentPath === '/guides' ? 'active' : ''}`}>Guides</a> -->
      <a href="/contact" class={`nav-link ${currentPath === '/contact' ? 'active' : ''}`}>Contact</a>
      <a class="btn-wa" href="https://wa.me/918072807474" style="margin-top: 24px; justify-content: center; width: 100%;">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width: 20px; height: 20px;"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Zm5.5 14.1c-.2.7-1.3 1.3-1.9 1.4-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.7-.6-2.9-1.3-4.8-4.2-5-4.4-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.3-.3.6-.4.8-.4h.6c.2 0 .4 0 .6.5s.8 1.9.9 2c.1.1.1.3 0 .5-.1.2-.2.3-.3.5l-.5.6c-.1.1-.3.3-.1.6.2.3.8 1.3 1.7 2.1 1.2 1.1 2.2 1.4 2.5 1.5.3.1.5.1.7-.1.2-.2.8-.9 1-1.2.2-.3.4-.3.7-.2.3.1 1.8.9 2.1 1 .3.2.5.2.6.4.1.1.1.7-.1 1.3Z"/></svg>
        WhatsApp Us
      </a>
    </nav>
  </div>
</header>

<style is:global>
  .nav-link {
    color: var(--c-t2);
    text-decoration: none;
    position: relative;
    padding: 4px 0;
    transition: color 0.3s var(--ease);
  }
  .nav-link:hover {
    color: var(--c-paper);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--c-gold);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s var(--ease);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  .nav-link.active {
    color: var(--c-gold);
  }
  .nav-link.active::after {
    transform: scaleX(1);
    background: var(--c-gold);
    transform-origin: left;
  }

  .mobile-toggle {
    display: none;
  }

  .mobile-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background: rgba(11,20,26,0.98);
    z-index: 101;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s var(--ease);
  }

  .mobile-drawer.open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    font-size: 24px;
    font-weight: 600;
    font-family: var(--f-disp);
    transform: translateY(20px);
    transition: transform 0.4s var(--ease);
  }

  .mobile-drawer.open .mobile-nav {
    transform: translateY(0);
  }

  /* Hamburger Animation */
  .menu-open .l1 { opacity: 0; }
  .menu-open .l2 { transform: translateY(6px) rotate(45deg); transform-origin: center; }
  .menu-open .l3 { transform: translateY(-6px) rotate(-45deg); transform-origin: center; }

  @media(max-width: 900px) {
    .desktop-nav {
      display: none !important;
    }
    .mobile-toggle {
      display: block;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.contains('open');
      if (isOpen) {
        menu.classList.remove('open');
        toggle.classList.remove('menu-open');
        document.body.style.overflow = '';
      } else {
        menu.classList.add('open');
        toggle.classList.add('menu-open');
        document.body.style.overflow = 'hidden';
      }
    });

    // Close menu when clicking a link
    menu.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('open');
        toggle.classList.remove('menu-open');
        document.body.style.overflow = '';
      });
    });
  }
</script>
