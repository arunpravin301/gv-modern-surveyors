---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Land surveys, FMB sketches and construction marking across India. A field team on your site, every working day." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<!-- Custom Cursor -->
		<div class="cursor-dot" id="cursor-dot"></div>
		<div class="cursor-crosshair" id="cursor-crosshair"></div>

		<!-- Ultra-Premium Preloader -->
		<div class="preloader" id="preloader">
			<div class="pl-laser" id="pl-laser"></div>
			<div class="pl-door pl-door-left" id="pl-door-left">
				<div class="pl-content-wrapper">
					<div class="pl-bg-text">GV MODERN SURVEYORS</div>
					<div class="pl-counter-huge" id="pl-counter-huge">0</div>
				</div>
			</div>
			<div class="pl-door pl-door-right" id="pl-door-right">
				<div class="pl-content-wrapper">
					<div class="pl-bg-text">GV MODERN SURVEYORS</div>
					<div class="pl-counter-huge" id="pl-counter-huge-right">0</div>
				</div>
			</div>
		</div>

		<slot />

		<script>
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			if (typeof window !== "undefined") {
				gsap.registerPlugin(ScrollTrigger);

				// Ultra-Premium Preloader Animation
				const preloader = document.getElementById('preloader');
				const plCounterLeft = document.getElementById('pl-counter-huge');
				const plCounterRight = document.getElementById('pl-counter-huge-right');
				const plLaser = document.getElementById('pl-laser');
				const doorLeft = document.getElementById('pl-door-left');
				const doorRight = document.getElementById('pl-door-right');

				if (preloader && plCounterLeft && plCounterRight) {
					// 1. Animate Counter
					const count = { val: 0 };
					gsap.to(count, {
						val: 100,
						duration: 2.2,
						ease: "power2.inOut",
						onUpdate: () => {
							const text = Math.round(count.val).toString();
							plCounterLeft.textContent = text;
							plCounterRight.textContent = text;
						}
					});

					// 2. Scale up counter at end
					gsap.to([plCounterLeft, plCounterRight], {
						scale: 1.5,
						opacity: 0,
						duration: 0.8,
						delay: 2.2,
						ease: "power3.in"
					});

					// 3. Laser Strike
					gsap.to(plLaser, {
						scaleY: 1,
						duration: 0.4,
						delay: 2.4,
						ease: "power4.inOut"
					});
					gsap.to(plLaser, {
						opacity: 0,
						duration: 0.3,
						delay: 2.8,
						ease: "power2.out"
					});

					// 4. Split Doors
					gsap.to(doorLeft, {
						x: "-100%",
						duration: 1.2,
						delay: 2.7,
						ease: "power4.inOut"
					});
					gsap.to(doorRight, {
						x: "100%",
						duration: 1.2,
						delay: 2.7,
						ease: "power4.inOut",
						onComplete: () => {
							preloader.style.display = 'none';
						}
					});
				}

				// Custom Cursor Logic
				const cursorDot = document.getElementById('cursor-dot');
				const cursorCrosshair = document.getElementById('cursor-crosshair');

				if (cursorDot && cursorCrosshair && matchMedia('(pointer: fine)').matches) {
					const xToDot = gsap.quickTo(cursorDot, "x", { duration: 0.1, ease: "power3" });
					const yToDot = gsap.quickTo(cursorDot, "y", { duration: 0.1, ease: "power3" });
					
					const xToRing = gsap.quickTo(cursorCrosshair, "x", { duration: 0.4, ease: "power3.out" });
					const yToRing = gsap.quickTo(cursorCrosshair, "y", { duration: 0.4, ease: "power3.out" });

					window.addEventListener('mousemove', (e) => {
						xToDot(e.clientX);
						yToDot(e.clientY);
						xToRing(e.clientX);
						yToRing(e.clientY);
					});

					// Hover states for interactive elements
					const setupHover = () => {
						const interactables = document.querySelectorAll('a, button');
						interactables.forEach((el) => {
							// Prevent duplicate listeners if this runs multiple times
							el.removeEventListener('mouseenter', handleMouseEnter);
							el.removeEventListener('mouseleave', handleMouseLeave);
							
							el.addEventListener('mouseenter', handleMouseEnter);
							el.addEventListener('mouseleave', handleMouseLeave);
						});
					};

					const handleMouseEnter = () => cursorCrosshair.classList.add('hover-active');
					const handleMouseLeave = () => cursorCrosshair.classList.remove('hover-active');

					setupHover();
					
					// Re-run setup if the DOM changes (e.g. Astro page transitions)
					document.addEventListener('astro:page-load', setupHover);
				}

				// Global fade-up animation
				const fadeUpElements = gsap.utils.toArray('.gsap-fade-up');
				fadeUpElements.forEach((el: any) => {
					gsap.fromTo(el, 
						{ y: 60, opacity: 0 },
						{
							y: 0,
							opacity: 1,
							duration: 1,
							ease: "power3.out",
							scrollTrigger: {
								trigger: el,
								start: "top 85%",
								toggleActions: "play none none reverse"
							}
						}
					);
				});

				// Global staggered fade-up for children (e.g., grids, lists)
				const staggerContainers = gsap.utils.toArray('.gsap-stagger-container');
				staggerContainers.forEach((container: any) => {
					const children = container.querySelectorAll('.gsap-stagger-item');
					if (children.length > 0) {
						gsap.fromTo(children,
							{ y: 60, opacity: 0 },
							{
								y: 0,
								opacity: 1,
								stagger: 0.15,
								duration: 1,
								ease: "power3.out",
								scrollTrigger: {
									trigger: container,
									start: "top 80%",
									toggleActions: "play none none reverse"
								}
							}
						);
					}
				});
			}
		</script>
	</body>
</html>
