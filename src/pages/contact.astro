---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

import '../styles/global.css';
---

<Layout title="Contact Us | GV Modern Surveyors">
	<Navigation />
	<main style="padding-top: 80px;">
        
    <section style="padding: 120px 0; border-bottom: 1px solid var(--c-border); background: var(--c-bg);">
      <div class="wrap">
        <div class="mono" style="color: var(--c-gold); margin-bottom: 24px; display: flex; align-items: center; gap: 12px;">
          / COMMUNICATIONS
          <span style="display: block; width: 80px; height: 1px; background: var(--c-border);"></span>
        </div>
        <h1 style="font-family: var(--f-disp); font-size: clamp(48px, 8vw, 120px); color: var(--c-paper); font-weight: 800; line-height: 0.9; margin-bottom: 40px; text-transform: uppercase;">
          Get in<br/>Touch
        </h1>
        <p style="font-size: 18px; color: var(--c-t2); max-width: 48ch; line-height: 1.6;">
          Send us an enquiry to check availability and get an exact quote. Most surveys can be scheduled for the very next morning.
        </p>
      </div>
    </section>

    <section style="background: var(--c-bg-alt); border-bottom: 1px solid var(--c-border);">
      <div class="wrap" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0;">
        
        <div style="padding: 80px 4vw 80px 0; border-right: 1px solid var(--c-border); display: flex; flex-direction: column; gap: 40px;">
          <div>
            <h3 class="mono" style="color: var(--c-t3); margin-bottom: 16px;">PHONE</h3>
            <a href="tel:+918072807474" style="font-family: var(--f-disp); font-size: 24px; font-weight: 700; color: var(--c-paper); text-decoration: none;">+91 80728 07474</a>
          </div>
          
          <div>
            <h3 class="mono" style="color: var(--c-t3); margin-bottom: 16px;">EMAIL</h3>
            <a href="mailto:gvmodernsurveyors2022@gmail.com" style="font-family: var(--f-disp); font-size: 20px; font-weight: 700; color: var(--c-paper); text-decoration: none;">gvmodernsurveyors2022@gmail.com</a>
          </div>
          
          <div>
            <h3 class="mono" style="color: var(--c-t3); margin-bottom: 16px;">ADDRESS</h3>
            <address style="font-style: normal; font-size: 17px; color: var(--c-t2); line-height: 1.6; max-width: 32ch;">
              No.117, Sammandhan Nagar Main Road,<br/>
              Kundrathur, Chennai 600069
            </address>
          </div>

          <div>
            <h3 class="mono" style="color: var(--c-t3); margin-bottom: 16px;">WEBSITE</h3>
            <a href="https://www.gvmodernsurveyors.in" style="font-family: var(--f-disp); font-size: 20px; font-weight: 700; color: var(--c-gold); text-decoration: none;">www.gvmodernsurveyors.in</a>
          </div>
        </div>

        <div style="padding: 80px 0 80px 4vw;">
          <div class="mono" style="color: var(--c-gold); margin-bottom: 24px;">/ DIRECT ENQUIRY</div>
          
          <form id="contactForm" onsubmit="event.preventDefault();" style="display: flex; flex-direction: column; gap: 16px;">
            <input type="text" name="name" placeholder="Your Name" required class="br-input" />
            <input type="tel" name="phone" placeholder="Phone Number" required class="br-input" />
            <select name="service" required class="br-input" style="cursor: pointer; appearance: none;">
              <option value="" disabled selected>Select Service Required</option>
              <option value="Topographical Survey">Topographical Survey</option>
              <option value="Building Setting Out">Building Setting Out Work</option>
              <option value="Road Survey">Road Survey</option>
              <option value="Hills Survey">Hills Survey</option>
              <option value="Highway Survey">Highway Survey</option>
              <option value="FMB & Contour">FMB & Contour Survey</option>
              <option value="Pipeline Survey">Pipeline Survey</option>
              <option value="Layout Marking">Layout Design & Marking</option>
              <option value="Quantity Survey">Quantity Survey</option>
              <option value="DGPS Survey">DGPS Survey</option>
            </select>
            <textarea name="message" placeholder="Location, plot size, or specific details..." rows="4" class="br-input" style="resize: vertical;"></textarea>
            
            <button id="waSubmit" type="submit" style="width: 100%; background: var(--c-gold); color: var(--c-bg); font-family: var(--f-body); font-weight: 700; font-size: 16px; padding: 18px; border: none; cursor: pointer; margin-top: 12px; transition: background 0.2s, transform 0.2s;">
              SEND VIA WHATSAPP
            </button>
            <p style="font-size: 13px; color: var(--c-t3); margin-top: 8px; text-align: center;">
              This will open WhatsApp with your details pre-filled.
            </p>
          </form>
        </div>

      </div>
    </section>

	</main>
  <Footer />
</Layout>

<style>
  .br-input {
    width: 100%;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    color: var(--c-paper);
    font-family: var(--f-body);
    font-size: 15px;
    padding: 16px;
    transition: border-color 0.2s;
  }
  .br-input::placeholder {
    color: var(--c-t3);
  }
  .br-input:focus {
    outline: none;
    border-color: var(--c-gold);
  }
  #waSubmit:hover {
    background: #f5c500;
    transform: translateY(-2px);
  }

  @media(max-width: 900px) {
    div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
    div[style*="border-right: 1px solid"] {
      border-right: none !important;
      border-bottom: 1px solid var(--c-border) !important;
      padding: 60px 0 !important;
    }
    div[style*="padding: 80px 0 80px 4vw;"] {
      padding: 60px 0 !important;
    }
  }
</style>

<script>
  if (typeof window !== "undefined") {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const btn = document.getElementById('waSubmit');
    if (btn && form) {
      btn.addEventListener('click', () => {
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        const n = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
        const p = (form.elements.namedItem('phone') as HTMLInputElement).value.trim();
        const s = (form.elements.namedItem('service') as HTMLSelectElement).value;
        const m = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();
        
        let text = 'Hi GV Modern Surveyors, I would like to enquire.%0A%0AName: ' + encodeURIComponent(n) + '%0APhone: ' + encodeURIComponent(p) + '%0AService: ' + encodeURIComponent(s);
        if (m) text += '%0ADetails: ' + encodeURIComponent(m);
        
        window.open('https://wa.me/918072807474?text=' + text, '_blank');
      });
    }
  }
</script>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  if (typeof window !== "undefined") {
    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo('.wrap h1', 
      { y: 40, opacity: 0 },
      { y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.2 }
    );
    gsap.fromTo('.wrap p', 
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.4 }
    );

    gsap.fromTo('form',
      { y: 40, opacity: 0 },
      {
        y: 0, opacity: 1, duration: 1, ease: 'power3.out',
        scrollTrigger: {
          trigger: 'form',
          start: 'top 90%'
        }
      }
    );
  }
</script>
