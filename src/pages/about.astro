---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import FinalCTA from '../components/FinalCTA.astro';

import '../styles/global.css';
---

<Layout title="About | GV Modern Surveyors">
	<Navigation />
	<main style="padding-top: 80px;">
        
    <section style="padding: 120px 0; border-bottom: 1px solid var(--c-border); background: var(--c-bg);">
      <div class="wrap">
        <div class="mono" style="color: var(--c-gold); margin-bottom: 24px; display: flex; align-items: center; gap: 12px;">
          / THE FIRM
          <span style="display: block; width: 80px; height: 1px; background: var(--c-border);"></span>
        </div>
        <h1 style="font-family: var(--f-disp); font-size: clamp(48px, 8vw, 120px); color: var(--c-paper); font-weight: 800; line-height: 0.9; margin-bottom: 40px; text-transform: uppercase;">
          Zero<br/>Deviation.
        </h1>
        <p style="font-size: 18px; color: var(--c-t2); max-width: 48ch; line-height: 1.6;">
          Founded in 2012, GV Modern Surveyors was built on a single, uncompromising principle: measurement is an exact science. We leave no room for guesswork, relying exclusively on state-of-the-art surveying hardware and rigorous mathematical cross-checks.
        </p>
      </div>
    </section>

    <section style="background: var(--c-bg-alt); padding: 100px 0; border-bottom: 1px solid var(--c-border);">
      <div class="wrap" style="display: grid; grid-template-columns: 1fr 1fr; gap: 8vw; align-items: center;">
        <div>
          <div class="mono" style="color: var(--c-gold); margin-bottom: 24px;">HARDWARE ARSENAL</div>
          <h2 style="font-size: clamp(32px, 4vw, 48px); margin-bottom: 24px; color: var(--c-paper);">Robotic Total Stations</h2>
          <p style="color: var(--c-t2); font-size: 17px; line-height: 1.6; margin-bottom: 32px;">
            Our primary measurement tools are Leica and Trimble robotic total stations. These instruments use electronic transit theodolites in conjunction with electronic distance meters (EDM) to read slope distances from the instrument to a particular point with 1mm accuracy.
          </p>
          <ul style="color: var(--c-paper); list-style: none; display: flex; flex-direction: column; gap: 12px; font-size: 15px;">
            <li style="display: flex; gap: 12px;"><span style="color: var(--c-gold);">+</span> 1mm / 1ppm distance accuracy</li>
            <li style="display: flex; gap: 12px;"><span style="color: var(--c-gold);">+</span> 1" angular accuracy</li>
            <li style="display: flex; gap: 12px;"><span style="color: var(--c-gold);">+</span> Reflectorless measurement up to 1000m</li>
          </ul>
        </div>
        <div class="about-img-wrap" style="aspect-ratio: 4/5; background: var(--c-bg); border: 1px solid var(--c-border); position: relative; overflow: hidden;">
          <img src="/img/total_station.png" alt="Total Station" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) brightness(0.8) contrast(1.2);" />
          <div style="position: absolute; inset: 0; background: linear-gradient(160deg, rgba(224,165,38,0.1), transparent); pointer-events: none;"></div>
          <div class="scan-line"></div>
          <div class="mono" style="position: absolute; bottom: 20px; right: 20px; color: var(--c-gold); font-size: 10px;">EQ.01 // TOTAL STATION</div>
        </div>
      </div>
    </section>

    <section style="background: var(--c-bg-alt); padding: 100px 0; border-bottom: 1px solid var(--c-border);">
      <div class="wrap" style="display: grid; grid-template-columns: 1fr 1fr; gap: 8vw; align-items: center;">
        <div class="about-img-wrap" style="aspect-ratio: 4/5; background: var(--c-bg); border: 1px solid var(--c-border); position: relative; overflow: hidden; order: -1;">
          <img src="/img/dgps_rover.png" alt="DGPS Rover" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) brightness(0.8) contrast(1.2);" />
          <div style="position: absolute; inset: 0; background: linear-gradient(160deg, rgba(224,165,38,0.1), transparent); pointer-events: none;"></div>
          <div class="scan-line" style="animation-delay: 2s;"></div>
          <div class="mono" style="position: absolute; bottom: 20px; left: 20px; color: var(--c-gold); font-size: 10px;">EQ.02 // DGPS ROVER</div>
        </div>
        <div class="dgps-text">
          <div class="mono" style="color: var(--c-gold); margin-bottom: 24px;">HARDWARE ARSENAL</div>
          <h2 style="font-size: clamp(32px, 4vw, 48px); margin-bottom: 24px; color: var(--c-paper);">Dual-Frequency DGPS</h2>
          <p style="color: var(--c-t2); font-size: 17px; line-height: 1.6; margin-bottom: 32px;">
            For massive 100+ acre tracts and global coordinate tying, we deploy Differential GPS (DGPS) rovers. By using a stationary base station and a roving receiver, we eliminate atmospheric interference and pinpoint coordinates to within centimeters globally.
          </p>
          <ul style="color: var(--c-paper); list-style: none; display: flex; flex-direction: column; gap: 12px; font-size: 15px;">
            <li style="display: flex; gap: 12px;"><span style="color: var(--c-gold);">+</span> Real-Time Kinematic (RTK) positioning</li>
            <li style="display: flex; gap: 12px;"><span style="color: var(--c-gold);">+</span> Sub-centimeter network accuracy</li>
            <li style="display: flex; gap: 12px;"><span style="color: var(--c-gold);">+</span> Global coordinate system (WGS84) integration</li>
          </ul>
        </div>
      </div>
    </section>

    <FinalCTA />
	</main>
  <Footer />
</Layout>

<style>
  @media(max-width: 900px) {
    div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
    .dgps-text {
      order: -2 !important;
    }
  }

  .scan-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--c-gold);
    box-shadow: 0 0 10px var(--c-gold);
    opacity: 0.5;
    animation: scan 4s linear infinite;
    pointer-events: none;
  }
  @keyframes scan {
    0% { top: 0%; opacity: 0; }
    10% { opacity: 0.5; }
    90% { opacity: 0.5; }
    100% { top: 100%; opacity: 0; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  if (typeof window !== "undefined") {
    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo('.wrap h1', 
      { y: 40, opacity: 0 },
      { y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.2 }
    );
    gsap.fromTo('.wrap p', 
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.4 }
    );

    const sections = gsap.utils.toArray('section:not(:first-child)');
    sections.forEach((sec: any) => {
      gsap.fromTo(sec,
        { y: 80, opacity: 0 },
        {
          y: 0, opacity: 1, duration: 1, ease: 'power3.out',
          scrollTrigger: {
            trigger: sec,
            start: 'top 85%'
          }
        }
      );
    });
  }
</script>
